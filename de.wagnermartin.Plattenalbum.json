{
  "app-id": "de.wagnermartin.Plattenalbum",
  "runtime": "org.gnome.Platform",
  "runtime-version": "master",
  "sdk": "org.gnome.Sdk",
  "command": "plattenalbum",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri",
    "--share=network",
    "--filesystem=xdg-music:ro",
    "--filesystem=xdg-run/mpd:ro",
    "--filesystem=/run/mpd:ro"
  ],
  "modules": [
    {
      "name": "plattenalbum",
      "sources": [{
        "type": "dir",
        "path": "."
      }],
      "builddir" : true,
      "buildsystem": "meson"
    }
  ]
}
